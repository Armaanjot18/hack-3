PORT=3000
NODE_ENV=development
JWT_SECRET=replace_with_a_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_random_string_at_least_32_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7
DB_URL=./medicheck-db.json
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_MAX=8
MAPS_PROVIDER=osm
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_USER_AGENT=MediCheck/1.0 (contact: support@medicheck.local)
MAPS_TIMEOUT_MS=10000
OVERPASS_MAX_RETRIES=2
HOSPITALS_CACHE_TTL_MS=600000
GEOCODE_CACHE_TTL_MS=86400000
GEMINI_API_KEY=your_google_gemini_api_key_here
